{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["package.json", "pnpm-lock.yaml", "pnpm-workspace.yaml"],
  "globalEnv": ["CI", "NODE_ENV"],
  "tasks": {
    "compile": {
      "dependsOn": ["^compile"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^compile"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^compile"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^compile"],
      "env": ["LANG", "LC_ALL", "TZ"],
      "outputs": ["coverage/**"]
    },
    "build": {
      "dependsOn": ["^compile"],
      "outputs": ["dist/**", ".output/**"]
    },
    "test:typecheck": {
      "dependsOn": ["^compile"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile"]
    }
  }
}
