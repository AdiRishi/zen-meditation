{
  "cli": {
    "version": ">= 21.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "node": "24.13.0",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "EAS_USE_CACHE": "1"
      }
    },
    "preview": {
      "node": "24.13.0",
      "distribution": "internal",
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "EAS_USE_CACHE": "1"
      }
    },
    "production": {
      "node": "24.13.0",
      "autoIncrement": true,
      "env": {
        "EAS_GRADLE_CACHE": "1",
        "EAS_USE_CACHE": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6791549985"
      },
      "android": {
        "track": "alpha"
      }
    }
  }
}
