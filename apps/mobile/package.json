{
  "name": "@repo/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "test": "jest --watchman=false",
    "test:types": "tsc --noEmit -p tests/tsconfig.json",
    "pretypecheck": "expo customize tsconfig.json",
    "typecheck": "tsc --noEmit && pnpm run test:types"
  },
  "dependencies": {
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo-google-fonts/newsreader": "^0.4.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-segmented-control/segmented-control": "2.5.7",
    "@shopify/react-native-skia": "2.8.0",
    "expo": "~57.0.4",
    "expo-audio": "~57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-keep-awake": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-navigation-bar": "~57.0.1",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "heroui-native": "^1.0.5",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "uniwind": "^1.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^25.9.5",
    "@types/react": "~19.2.17",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "serve-sim": "^0.1.44",
    "typescript": "~6.0.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@shopify/react-native-skia"
      ]
    }
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "@shopify/react-native-skia/jestEnv.js",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "setupFiles": [
      "<rootDir>/tests/testing-utils/jest-setup.ts"
    ],
    "setupFilesAfterEnv": [
      "@shopify/react-native-skia/jestSetup.js"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx,js,jsx}",
      "!src/**/*.d.ts",
      "!src/**/*.test.{ts,tsx,js,jsx}",
      "!src/**/*.spec.{ts,tsx,js,jsx}",
      "!src/**/index.{ts,tsx,js,jsx}"
    ],
    "coverageDirectory": "coverage/app",
    "coverageReporters": [
      "text-summary",
      "lcov"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.[jt]s?(x)"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/)?((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|native-base|react-native-svg|react-native-worklets|react-native-reanimated|@shopify(/|\\+)react-native-skia|react-native-gesture-handler|react-native-safe-area-context|heroui-native|uniwind|tailwind-variants|superjson|copy-anything|is-what))"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@tests/(.*)$": "<rootDir>/tests/$1"
    }
  }
}
